<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Аца & Лиза — Навсегда любовь</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      overflow: hidden;
      background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .love-text {
      position: relative;
      z-index: 10;
      text-align: center;
      color: #fff;
      text-shadow: 0 4px 20px rgba(255,0,100,0.4), 0 0 40px rgba(255,0,100,0.2);
      animation: pulseText 3s ease-in-out infinite;
    }
    .love-text h1 {
      font-size: 4rem;
      margin: 0;
      font-weight: 800;
      letter-spacing: 2px;
      background: linear-gradient(90deg, #fff, #ffe4ec, #fff);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shine 4s linear infinite;
    }
    .love-text h2 {
      font-size: 2.2rem;
      margin: 15px 0 0;
      font-weight: 300;
      opacity: 0.95;
    }
    .emoji-row {
      font-size: 3rem;
      margin-top: 20px;
      animation: bounce 2s ease-in-out infinite;
    }
    .heart {
      position: absolute;
      pointer-events: none;
      animation: floatUp linear infinite, sway ease-in-out infinite alternate;
      opacity: 0.8;
      z-index: 2;
    }
    @keyframes floatUp {
      0% { transform: translateY(100vh) scale(0.5); opacity: 0; }
      10% { opacity: 0.9; }
      90% { opacity: 0.9; }
      100% { transform: translateY(-10vh) scale(1.2); opacity: 0; }
    }
    @keyframes sway {
      0% { margin-left: -30px; }
      100% { margin-left: 30px; }
    }
    @keyframes pulseText {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.03); }
    }
    @keyframes shine {
      0% { background-position: 0% center; }
      100% { background-position: 200% center; }
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-15px); }
    }
    .sparkle {
      position: absolute;
      width: 6px;
      height: 6px;
      background: white;
      border-radius: 50%;
      pointer-events: none;
      animation: sparkleAnim 2s ease-out forwards;
      z-index: 5;
    }
    @keyframes sparkleAnim {
      0% { transform: scale(0) rotate(0deg); opacity: 1; }
      100% { transform: scale(1.5) rotate(180deg); opacity: 0; }
    }
    .glow-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      opacity: 0.4;
      animation: orbMove 20s ease-in-out infinite alternate;
      z-index: 0;
    }
    @keyframes orbMove {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(50px, -30px) scale(1.3); }
    }
  </style>
</head>
<body id="loveContainer">
  <div class="glow-orb" style="width:300px;height:300px;background:#ff6b9d;top:10%;left:10%;"></div>
  <div class="glow-orb" style="width:250px;height:250px;background:#c44569;bottom:20%;right:15%;animation-delay:-5s;"></div>
  <div class="glow-orb" style="width:200px;height:200px;background:#f8b500;top:50%;left:60%;animation-delay:-10s;"></div>

  <div class="love-text">
    <h1>Аца & Лиза</h1>
    <h2>Навсегда любовь ❤️</h2>
    <div class="emoji-row">💕 💗 💝 💘 💞</div>
  </div>

  <script>
    const container = document.getElementById('loveContainer');
    const colors = ['#ff6b9d', '#ff4757', '#ff6348', '#ff9ff3', '#f368e0', '#ee5a24', '#ff3838', '#ff7979', '#fab1a0', '#e17055', '#fd79a8', '#e84393'];
    const heartSvgs = [
      '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>',
      '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/><circle cx="7" cy="7" r="1.5" fill="white" opacity="0.6"/><circle cx="17" cy="7" r="1.5" fill="white" opacity="0.6"/></svg>',
      '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/><path d="M8 12l2 2 6-6" stroke="white" stroke-width="1.5" fill="none" opacity="0.7"/></svg>'
    ];

    function createHeart() {
      const heart = document.createElement('div');
      heart.className = 'heart';
      const size = Math.random() * 50 + 20;
      const color = colors[Math.floor(Math.random() * colors.length)];
      const left = Math.random() * 100;
      const duration = Math.random() * 6 + 4;
      const delay = Math.random() * 2;
      const svg = heartSvgs[Math.floor(Math.random() * heartSvgs.length)];

      heart.style.cssText = `left:${left}%;width:${size}px;height:${size}px;color:${color};animation-duration:${duration}s,${duration*0.5}s;animation-delay:${delay}s,${delay}s;`;
      heart.innerHTML = svg;
      container.appendChild(heart);
      setTimeout(() => heart.remove(), (duration + delay) * 1000);
    }

    function createSparkle(x, y) {
      for (let i = 0; i < 5; i++) {
        const sparkle = document.createElement('div');
        sparkle.className = 'sparkle';
        const ox = (Math.random() - 0.5) * 60;
        const oy = (Math.random() - 0.5) * 60;
        sparkle.style.left = (x + ox) + 'px';
        sparkle.style.top = (y + oy) + 'px';
        sparkle.style.animationDelay = (Math.random() * 0.3) + 's';
        container.appendChild(sparkle);
        setTimeout(() => sparkle.remove(), 2000);
      }
    }

    setInterval(createHeart, 300);
    for (let i = 0; i < 20; i++) setTimeout(createHeart, i * 100);

    container.addEventListener('click', (e) => {
      createSparkle(e.clientX, e.clientY);
      for (let i = 0; i < 3; i++) setTimeout(createHeart, i * 50);
    });

    setInterval(() => {
      const textEl = document.querySelector('.love-text');
      const rect = textEl.getBoundingClientRect();
      createSparkle(rect.left + Math.random() * rect.width, rect.top + Math.random() * rect.height);
    }, 800);
  </script>
</body>
</html>
